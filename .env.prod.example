# =====================================================
# Diet Planner - Production Environment Configuration
# =====================================================
# Copy this file to .env.prod on your server and fill in values.
# Used with: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# NEVER commit .env.prod to version control!
# =====================================================

# =====================================================
# DOMAIN & SSL (Traefik / Let's Encrypt)
# =====================================================
DOMAIN=fittrack.yourdomain.com
ACME_EMAIL=you@email.com

# =====================================================
# DATABASE
# =====================================================
POSTGRES_USER=diet_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=fitness_track

# =====================================================
# SECURITY
# =====================================================
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX
ALGORITHM=HS256

# =====================================================
# LLM CONFIGURATION
# =====================================================
# Provider: "ollama" (container), "openrouter", or "openai"
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_MODEL=

# Ollama-specific (only needed if LLM_PROVIDER=ollama)
OLLAMA_API_KEY=your_ollama_key
OLLAMA_MODEL=gpt-oss:120b-cloud
# OLLAMA_URL defaults to http://ollama:11434 (the container)

# =====================================================
# CORS
# =====================================================
# Comma-separated extra allowed origins
CORS_ORIGINS=https://fittrack.yourdomain.com

# =====================================================
# TIMEZONE
# =====================================================
TZ=Asia/Kolkata

# =====================================================
# LANGFUSE (Self-hosted LLM Observability)
# =====================================================
# Subdomain for Langfuse UI (defaults to langfuse.${DOMAIN})
# LANGFUSE_DOMAIN=langfuse.fittrack.yourdomain.com
# Generate both: python -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_GENERATE_RANDOM
LANGFUSE_SALT=CHANGE_ME_GENERATE_RANDOM
# These keys are auto-provisioned into the Langfuse project
LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
# Points to local container (no need to change)
LANGFUSE_HOST=http://langfuse:3000
# ClickHouse password (internal, pick anything)
LANGFUSE_CLICKHOUSE_PASSWORD=langfuse
